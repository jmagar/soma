# =============================================================================
# .gitattributes — Git LFS tracking rules for rmcp-template
#
# TEMPLATE: Plugins do not bundle server binaries. Release archives may still be
#           tracked via Git LFS when intentionally checked in.
# =============================================================================

# ── Release archives ──────────────────────────────────────────────────────────
# TEMPLATE: If your release workflow produces tarballs or zips (e.g. for GitHub
#           Releases), track them here too so they don't bloat git history.
*.tar.gz filter=lfs diff=lfs merge=lfs -text
*.zip filter=lfs diff=lfs merge=lfs -text

# ── Optional: other binary types ──────────────────────────────────────────────
# TEMPLATE: Uncomment if you ship .wasm modules, .so shared libs, or other
#           large binary formats as part of the plugin distribution.
# *.wasm filter=lfs diff=lfs merge=lfs -text
# *.so   filter=lfs diff=lfs merge=lfs -text
# *.dylib filter=lfs diff=lfs merge=lfs -text
