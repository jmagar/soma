# =============================================================================
# .env.example - generated secrets and URLs sample
#
# CUSTOMIZE: Rename SOMA_* throughout to your service's prefix.
# Secrets and URLs go here; non-secret defaults belong in config.toml.
# Regenerate with: cargo xtask generate-docs
# =============================================================================

# Upstream service

# Shared runtime / plugin settings
# Deployed platform API or upstream API base URL used by `SomaClient`. Empty selects offline stub mode.
SOMA_API_URL=https://api.example.com

# Bearer token or upstream API key. Keep secret. Required when the deployed API requires auth.
SOMA_API_KEY=your-api-key-here

# Optional remote/platform HTTP server URL used by plugin setup and health checks.
# SOMA_SERVER_URL=http://localhost:40060

# `bearer` or `oauth`.
# SOMA_MCP_AUTH_MODE=bearer

# Public URL used for OAuth metadata endpoints.
# SOMA_MCP_PUBLIC_URL=https://example.yourdomain.com

# Trusted inbound HTTP trace-header extraction: `off`, `trusted`, or `trusted-with-baggage`. Enable only behind a transport-level trust boundary; see `docs/TRACE_CONTEXT.md`.
# SOMA_MCP_TRACE_HEADERS=off


# MCP auth and trusted operator bootstrap
# Static bearer token. Required for bearer-only mounted HTTP.
# SOMA_MCP_TOKEN=

# Disable local auth for loopback development only.
# SOMA_MCP_NO_AUTH=false

# Trusted-gateway no-auth mode for non-loopback deployments where an upstream proxy enforces auth.
# SOMA_NOAUTH=false

# Google OAuth client ID.
# SOMA_MCP_GOOGLE_CLIENT_ID=123456789-abcdefg.apps.googleusercontent.com

# Google OAuth client secret.
# SOMA_MCP_GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here

# Google callback path (default: `/auth/google/callback`).
# SOMA_MCP_GOOGLE_CALLBACK_PATH=/auth/google/callback

# Comma-separated Google scopes (default: `openid,email,profile`).
# SOMA_MCP_GOOGLE_SCOPES=openid,email,profile

# Authelia OIDC issuer URL. HTTPS is required.
# SOMA_MCP_AUTHELIA_ISSUER_URL=https://auth.example.com

# Authelia OIDC client ID.
# SOMA_MCP_AUTHELIA_CLIENT_ID=soma

# Authelia OIDC client secret.
# SOMA_MCP_AUTHELIA_CLIENT_SECRET=your-authelia-client-secret

# Authelia callback path (default: `/auth/authelia/callback`).
# SOMA_MCP_AUTHELIA_CALLBACK_PATH=/auth/authelia/callback

# Comma-separated Authelia scopes (default: `openid,email,profile,offline_access`).
# SOMA_MCP_AUTHELIA_SCOPES=openid,email,profile,offline_access

# GitHub OAuth App client ID.
# SOMA_MCP_GITHUB_CLIENT_ID=your-github-oauth-app-client-id

# GitHub OAuth App client secret.
# SOMA_MCP_GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# GitHub callback path (default: `/auth/github/callback`).
# SOMA_MCP_GITHUB_CALLBACK_PATH=/auth/github/callback

# Comma-separated GitHub scopes; must include `user:email` (default: `read:user,user:email`).
# SOMA_MCP_GITHUB_SCOPES=read:user,user:email

# Provider used when `provider` is omitted: `google`, `authelia`, or `github`; automatic priority is Google, Authelia, GitHub.
# SOMA_MCP_AUTH_DEFAULT_PROVIDER=authelia

# Initial/admin email allowed by the OAuth flow.
# SOMA_MCP_AUTH_ADMIN_EMAIL=admin@example.com

# Grant the static bearer token `soma:write` in addition to `soma:read`. Read-only by default.
# SOMA_MCP_STATIC_TOKEN_WRITE=

# Native-flow bootstrap secret for the desktop/CLI OAuth poll flow.
# SOMA_MCP_AUTH_BOOTSTRAP_SECRET=

# Auth SQLite DB path. Unset uses the built-in default under the data dir.
# SOMA_MCP_AUTH_SQLITE_PATH=

# Ed25519 JWT signing key path. Unset uses the built-in default under the data dir.
# SOMA_MCP_AUTH_KEY_PATH=

# Access-token lifetime in seconds. Unset uses the built-in auth default.
# SOMA_MCP_AUTH_ACCESS_TOKEN_TTL_SECS=

# Refresh-token lifetime in seconds. Unset uses the built-in auth default.
# SOMA_MCP_AUTH_REFRESH_TOKEN_TTL_SECS=

# Authorization-code lifetime in seconds. Unset uses the built-in auth default.
# SOMA_MCP_AUTH_CODE_TTL_SECS=

# Per-IP `/register` rate limit. Unset uses the built-in auth default.
# SOMA_MCP_AUTH_REGISTER_REQUESTS_PER_MINUTE=

# Per-IP `/authorize` rate limit. Unset uses the built-in auth default.
# SOMA_MCP_AUTH_AUTHORIZE_REQUESTS_PER_MINUTE=

# Cap on pending OAuth state rows (DoS bound). Unset uses the built-in auth default.
# SOMA_MCP_AUTH_MAX_PENDING_OAUTH_STATES=

# Comma-separated allowlist of dynamic-client redirect URIs.
# SOMA_MCP_AUTH_ALLOWED_REDIRECT_URIS=

# At-rest encryption key for stored provider refresh tokens (64-hex or 43-char base64url). Keep secret.
# SOMA_MCP_TOKEN_ENCRYPTION_KEY=


# MCP HTTP server compose overrides
# Bind host for HTTP transport. Set `0.0.0.0` only with bearer, OAuth, or trusted-gateway auth configured.
# SOMA_MCP_HOST=127.0.0.1

# MCP server name advertised to clients.
# SOMA_MCP_SERVER_NAME=soma

# Bind port for HTTP transport.
# SOMA_MCP_PORT=40060

# Extra accepted Host header values, comma-separated.
# SOMA_MCP_ALLOWED_HOSTS=example.yourdomain.com

# Extra CORS origins, comma-separated.
# SOMA_MCP_ALLOWED_ORIGINS=https://claude.ai

# Docker runtime
# PUID=1000
# PGID=1000
# DOCKER_NETWORK=mcp
# VERSION=latest

# Logging
# RUST_LOG=info
# NO_COLOR=1
# FORCE_COLOR=1
