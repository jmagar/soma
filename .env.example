# =============================================================================
# .env.example - generated secrets and URLs template
#
# TEMPLATE: Rename RTEMPLATE_* throughout to your service's prefix.
# Secrets and URLs go here; non-secret defaults belong in config.toml.
# Regenerate with: cargo xtask generate-docs
# =============================================================================

# Upstream service

# Shared runtime / plugin settings
# Deployed platform API or upstream API base URL used by `ExampleClient`. Empty selects offline template stub mode.
RTEMPLATE_API_URL=https://api.example.com/v1

# Bearer token or upstream API key. Keep secret. Required when the deployed API requires auth.
RTEMPLATE_API_KEY=your-api-key-here

# Optional remote/platform HTTP server URL used by plugin setup and health checks.
# RTEMPLATE_SERVER_URL=http://localhost:40060

# `bearer` or `oauth`.
# RTEMPLATE_MCP_AUTH_MODE=bearer

# Public URL used for OAuth metadata endpoints.
# RTEMPLATE_MCP_PUBLIC_URL=https://example.yourdomain.com


# MCP auth and trusted operator bootstrap
# Static bearer token. Required for bearer-only mounted HTTP.
# RTEMPLATE_MCP_TOKEN=

# Disable local auth for loopback development only.
# RTEMPLATE_MCP_NO_AUTH=false

# Trusted-gateway no-auth mode for non-loopback deployments where an upstream proxy enforces auth.
# RTEMPLATE_NOAUTH=false

# Google OAuth client ID.
# RTEMPLATE_MCP_GOOGLE_CLIENT_ID=123456789-abcdefg.apps.googleusercontent.com

# Google OAuth client secret.
# RTEMPLATE_MCP_GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here

# Initial/admin email allowed by the OAuth flow.
# RTEMPLATE_MCP_AUTH_ADMIN_EMAIL=admin@example.com


# MCP HTTP server compose overrides
# Bind host for HTTP transport. Set `0.0.0.0` only with bearer, OAuth, or trusted-gateway auth configured.
# RTEMPLATE_MCP_HOST=127.0.0.1

# MCP server name advertised to clients.
# RTEMPLATE_MCP_SERVER_NAME=template-rmcp

# Bind port for HTTP transport.
# RTEMPLATE_MCP_PORT=40060

# Extra accepted Host header values, comma-separated.
# RTEMPLATE_MCP_ALLOWED_HOSTS=example.yourdomain.com

# Extra CORS origins, comma-separated.
# RTEMPLATE_MCP_ALLOWED_ORIGINS=https://claude.ai

# Docker runtime
# PUID=1000
# PGID=1000
# DOCKER_NETWORK=mcp
# VERSION=latest

# Logging
# RUST_LOG=info
# NO_COLOR=1
# FORCE_COLOR=1
