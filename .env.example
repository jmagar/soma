# =============================================================================
# .env.example — Secrets and URLs for the Example MCP server
#
# TEMPLATE: Rename EXAMPLE_* throughout to your service's prefix.
#           Replace "example" with your service name.
#
# SPLIT PHILOSOPHY — Rule of thumb:
#   Secrets and URLs go here (.env), everything else in config.toml.
#   Never put secrets in config.toml (it's checked into git).
#   Never put non-secret config here (it becomes hard to track).
#
# Concretely:
#   .env         → API URLs, API keys, tokens, OAuth credentials, passwords
#   config.toml  → Ports, bind addresses, feature flags, tuning knobs,
#                  timeouts, log levels, retention settings
#
# Usage:
#   cp .env.example .env
#   # Edit .env — fill in real values
#   # .env is in .gitignore; never commit it
# =============================================================================

# ── Upstream service ──────────────────────────────────────────────────────────
# TEMPLATE: These are the credentials for the remote service this MCP server
#           wraps. Rename to match your service (e.g. MYSERVICE_API_URL).
#
#           EXAMPLE_API_URL — full base URL of the remote API
#             e.g. https://api.example.com/v1   (REST)
#             e.g. https://graphql.example.com/graphql  (GraphQL)
#
#           EXAMPLE_API_KEY — API key / bearer token for the remote service.
#             Generate one in your service's developer console.
#             In src/example.rs, this is passed as a header or query param.

EXAMPLE_API_URL=https://api.example.com/v1
EXAMPLE_API_KEY=your-api-key-here

# ── MCP HTTP server ───────────────────────────────────────────────────────────
# EXAMPLE_MCP_TOKEN — static bearer token that MCP clients must present.
#   Every request to /mcp must include: Authorization: Bearer <this-value>
#   Generate with: openssl rand -hex 32   or   just gen-token
#   Omit (or set EXAMPLE_MCP_NO_AUTH=true) for loopback-only dev mode only.

# EXAMPLE_MCP_TOKEN=    # generate with: openssl rand -hex 32   or   just gen-token

# Disable auth entirely. ONLY safe when the server is bound to 127.x.
# Set to true only for local development when you control the machine.
# EXAMPLE_MCP_NO_AUTH=false

# ── OAuth (Google) ────────────────────────────────────────────────────────────
# TEMPLATE: Only needed when EXAMPLE_MCP_AUTH_MODE=oauth in config.toml.
#           Leave commented out for bearer-token-only mode (the simpler default).
#
# Steps to enable OAuth:
#   1. Create a Web application OAuth client at console.cloud.google.com
#   2. Add your redirect URIs (plugin-setup.sh does this automatically)
#   3. Set EXAMPLE_MCP_AUTH_MODE=oauth in config.toml
#   4. Fill in the values below

# Public URL of your MCP server (used as OAuth issuer / resource metadata URL).
# Must be reachable from clients. Required in OAuth mode.
# EXAMPLE_MCP_PUBLIC_URL=https://myservice.example.com

# Google OAuth 2.0 credentials
# EXAMPLE_MCP_GOOGLE_CLIENT_ID=123456789-abcdefg.apps.googleusercontent.com
# EXAMPLE_MCP_GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here

# Bootstrap admin email — first allowed Google account for OAuth
# EXAMPLE_MCP_AUTH_ADMIN_EMAIL=admin@example.com

# ── Logging ───────────────────────────────────────────────────────────────────
# TEMPLATE: Adjust as needed. info is a good default for production.
#           Use debug for development, warn for high-throughput servers.
# RUST_LOG=info
# RUST_LOG=info,rmcp=warn,example=debug
