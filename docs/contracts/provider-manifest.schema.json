{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://template-rmcp.local/schemas/provider-manifest.schema.json",
  "title": "rmcp-template Provider Manifest",
  "description": "Resolved provider manifest consumed by the dynamic provider runtime.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "provider"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "provider": {
      "$ref": "#/$defs/provider"
    },
    "tools": {
      "type": "array",
      "items": { "$ref": "#/$defs/tool" },
      "default": []
    },
    "prompts": {
      "type": "array",
      "items": { "$ref": "#/$defs/prompt" },
      "default": []
    },
    "resources": {
      "type": "array",
      "items": { "$ref": "#/$defs/resource" },
      "default": []
    },
    "tasks": {
      "type": "array",
      "items": { "$ref": "#/$defs/task" },
      "default": []
    },
    "elicitation": {
      "type": "array",
      "items": { "$ref": "#/$defs/elicitation" },
      "default": []
    },
    "env": {
      "type": "array",
      "items": { "$ref": "#/$defs/envRequirement" },
      "default": []
    },
    "capabilities": {
      "$ref": "#/$defs/hostCapabilities"
    },
    "docs": {
      "$ref": "#/$defs/docsOverlay"
    },
    "plugin": {
      "$ref": "#/$defs/pluginOverlay"
    },
    "ui": {
      "$ref": "#/$defs/uiOverlay"
    },
    "meta": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "$defs": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[-_][a-z0-9]+)*$"
    },
    "provider": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "kind"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "kind": {
          "type": "string",
          "enum": ["static-rust", "openapi", "ai-sdk", "wasm", "mcp"]
        },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "version": { "type": "string" },
        "homepage": { "type": "string", "format": "uri" },
        "source": { "type": "string" },
        "enabled": { "type": "boolean", "default": true }
      }
    },
    "jsonSchema": {
      "type": "object",
      "additionalProperties": true
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "input_schema"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "input_schema": { "$ref": "#/$defs/jsonSchema" },
        "output_schema": { "$ref": "#/$defs/jsonSchema" },
        "scope": { "type": "string" },
        "destructive": { "type": "boolean", "default": false },
        "requires_admin": { "type": "boolean", "default": false },
        "cost": {
          "type": "string",
          "enum": ["cheap", "moderate", "expensive", "write"],
          "default": "cheap"
        },
        "env": {
          "type": "array",
          "items": { "$ref": "#/$defs/envRequirement" },
          "default": []
        },
        "limits": { "$ref": "#/$defs/limits" },
        "mcp": { "$ref": "#/$defs/mcpToolOverlay" },
        "rest": { "$ref": "#/$defs/restOverlay" },
        "cli": { "$ref": "#/$defs/cliOverlay" },
        "palette": { "$ref": "#/$defs/paletteOverlay" },
        "ui": { "$ref": "#/$defs/uiOverlay" },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/$defs/example" },
          "default": []
        },
        "meta": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "arguments_schema": { "$ref": "#/$defs/jsonSchema" },
        "scope": { "type": "string" },
        "mcp": { "$ref": "#/$defs/mcpPrimitiveOverlay" },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/$defs/example" },
          "default": []
        }
      }
    },
    "resource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uri_template", "name", "description"],
      "properties": {
        "uri_template": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "mime_type": { "type": "string" },
        "scope": { "type": "string" },
        "mcp": { "$ref": "#/$defs/mcpPrimitiveOverlay" },
        "annotations": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "input_schema"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "description": { "type": "string" },
        "input_schema": { "$ref": "#/$defs/jsonSchema" },
        "output_schema": { "$ref": "#/$defs/jsonSchema" },
        "scope": { "type": "string" },
        "mcp": { "$ref": "#/$defs/mcpPrimitiveOverlay" },
        "limits": { "$ref": "#/$defs/limits" }
      }
    },
    "elicitation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description", "schema"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "description": { "type": "string" },
        "schema": { "$ref": "#/$defs/jsonSchema" },
        "scope": { "type": "string" },
        "mcp": { "$ref": "#/$defs/mcpPrimitiveOverlay" }
      }
    },
    "mcpPrimitiveOverlay": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "title": { "type": "string" },
        "icons": {
          "type": "array",
          "items": { "$ref": "#/$defs/icon" },
          "default": []
        },
        "annotations": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "mcpToolOverlay": {
      "allOf": [{ "$ref": "#/$defs/mcpPrimitiveOverlay" }]
    },
    "restOverlay": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "method": {
          "type": "string",
          "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"],
          "default": "POST"
        },
        "path": { "type": "string", "pattern": "^/v1(/.*)?$" },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "summary": { "type": "string" },
        "description": { "type": "string" },
        "deprecated": { "type": "boolean", "default": false }
      }
    },
    "cliOverlay": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "command": { "$ref": "#/$defs/name" },
        "aliases": {
          "type": "array",
          "items": { "$ref": "#/$defs/name" },
          "default": []
        },
        "about": { "type": "string" },
        "long_about": { "type": "string" },
        "flags": {
          "type": "array",
          "items": { "$ref": "#/$defs/cliFlag" },
          "default": []
        },
        "default_output": {
          "type": "string",
          "enum": ["json", "table", "plain", "yaml", "markdown"],
          "default": "json"
        },
        "interactive": { "type": "boolean", "default": false },
        "hidden": { "type": "boolean", "default": false }
      }
    },
    "paletteOverlay": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "category": { "type": "string" },
        "icon": { "type": "string" },
        "tone": {
          "type": "string",
          "enum": ["info", "success", "warn", "neutral", "rose", "orange"]
        },
        "arg_mode": {
          "type": "string",
          "enum": ["none", "optionalSingle", "single", "split", "schema"],
          "default": "schema"
        },
        "result_view": {
          "type": "string",
          "enum": ["auto", "json", "markdown", "table", "code", "artifact"],
          "default": "auto"
        },
        "aurora_blocks": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "uiOverlay": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": true },
        "aurora_registry_dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "shadcn_items": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "categories": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "meta": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "pluginOverlay": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "generate_skill": { "type": "boolean", "default": true },
        "generate_claude": { "type": "boolean", "default": true },
        "generate_codex": { "type": "boolean", "default": true },
        "generate_gemini": { "type": "boolean", "default": true },
        "generate_marketplace": { "type": "boolean", "default": true },
        "mcp_registration": {
          "type": "string",
          "enum": ["none", "plugin-root", "gemini-inline", "both"],
          "default": "none"
        }
      }
    },
    "docsOverlay": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "when_to_use": { "type": "string" },
        "examples": {
          "type": "array",
          "items": { "$ref": "#/$defs/example" },
          "default": []
        },
        "troubleshooting": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "timeout_ms": { "type": "integer", "minimum": 1 },
        "max_response_bytes": { "type": "integer", "minimum": 1 },
        "max_input_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "envRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9_]*$"
        },
        "description": { "type": "string" },
        "required": { "type": "boolean", "default": true },
        "sensitive": { "type": "boolean", "default": true },
        "server_prefixed": { "type": "boolean", "default": true },
        "allow_unprefixed": { "type": "boolean", "default": false },
        "default": {
          "type": ["string", "number", "boolean", "array", "object", "null"]
        }
      }
    },
    "hostCapabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "filesystem": { "$ref": "#/$defs/filesystemCapability" },
        "network": { "$ref": "#/$defs/networkCapability" },
        "env": { "$ref": "#/$defs/envCapability" },
        "terminal": { "$ref": "#/$defs/terminalCapability" },
        "browser": { "$ref": "#/$defs/browserCapability" },
        "github": { "$ref": "#/$defs/githubCapability" }
      }
    },
    "filesystemCapability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "read_roots": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "write_roots": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "networkCapability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "allowed_hosts": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "envCapability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "allowed": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "terminalCapability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "working_dir": { "type": "string" },
        "allowlist": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "browserCapability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "allowed_origins": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        }
      }
    },
    "githubCapability": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "allowed_repos": {
          "type": "array",
          "items": { "type": "string" },
          "default": []
        },
        "read_only": { "type": "boolean", "default": true }
      }
    },
    "parameter": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "schema": { "$ref": "#/$defs/jsonSchema" },
        "required": { "type": "boolean", "default": false },
        "description": { "type": "string" }
      }
    },
    "cliPositional": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "required": { "type": "boolean", "default": true },
        "description": { "type": "string" }
      }
    },
    "cliFlag": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "$ref": "#/$defs/name" },
        "long": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
        "short": { "type": "string", "minLength": 1, "maxLength": 1 },
        "required": { "type": "boolean", "default": false },
        "description": { "type": "string" }
      }
    },
    "example": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "input": true,
        "output": true,
        "cli": { "type": "string" },
        "rest": {
          "type": "object",
          "additionalProperties": true
        },
        "mcp": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "icon": {
      "type": "object",
      "additionalProperties": false,
      "required": ["src"],
      "properties": {
        "src": { "type": "string" },
        "mime_type": { "type": "string" },
        "sizes": { "type": "string" }
      }
    }
  }
}
