        ]
      }
    }
  },
  "servers": [
    {
      "description": "Default local development server",
      "url": "http://localhost:40060"
    }
  ],
  "tags": [
    {
      "description": "Unauthenticated runtime probes",
      "name": "health"
    },
    {
      "description": "REST route inventory",
      "name": "capabilities"
    },
    {
      "description": "Preferred typed REST routes",
      "name": "direct-rest"
    }
  ],
  "x-template": {
    "action_costs": {
      "echo": "cheap",
      "elicit_name": "cheap",
      "greet": "cheap",
      "help": "cheap",
      "scaffold_intent": "moderate",
      "status": "cheap"
    },
    "action_metadata": "crates/rtemplate-service/src/actions.rs",
    "direct_rest_routes": {
      "echo": {
        "method": "POST",
        "path": "/v1/echo"
      },
      "greet": {
        "method": "POST",
        "path": "/v1/greet"
      },
      "help": {
        "method": "GET",
        "path": "/v1/help"
      },
      "status": {
        "method": "GET",
        "path": "/v1/status"
      }
    },
    "mcp_only_actions": [
      "elicit_name",
      "scaffold_intent"
    ],
    "preferred_rest_style": "direct_routes",
    "rest_actions": [
      "greet",
      "echo",
      "status",
      "help"
    ],
    "source": "cargo xtask check-openapi"
  }
}
