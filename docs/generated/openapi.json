{
  "components": {
    "responses": {
      "BadRequest": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        },
        "description": "Validation error"
      },
      "Forbidden": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        },
        "description": "Authenticated request lacks the required scope"
      },
      "InternalError": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        },
        "description": "Internal server error"
      },
      "Unauthorized": {
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorResponse"
            }
          }
        },
        "description": "Missing or invalid authentication"
      }
    },
    "schemas": {
      "ActionName": {
        "description": "REST-capable action names from crates/rtemplate-service/src/actions.rs.",
        "enum": [
          "greet",
          "echo",
          "status",
          "help"
        ],
        "type": "string"
      },
      "ActionResponse": {
        "oneOf": [
          {
            "$ref": "#/components/schemas/GreetResponse"
          },
          {
            "$ref": "#/components/schemas/EchoResponse"
          },
          {
            "$ref": "#/components/schemas/StatusResponse"
          },
          {
            "$ref": "#/components/schemas/HelpResponse"
          },
          {
            "$ref": "#/components/schemas/RestTruncationResponse"
          }
        ]
      },
      "CapabilitiesResponse": {
        "additionalProperties": false,
        "properties": {
          "preferred_rest_style": {
            "const": "direct_routes",
            "type": "string"
          },
          "routes": {
            "items": {
              "$ref": "#/components/schemas/RestRoute"
            },
            "type": "array"
          },
          "server": {
            "type": "string"
          },
          "supported_routes": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "version": {
            "type": "string"
          }
        },
        "required": [
          "server",
          "version",
          "preferred_rest_style",
          "supported_routes",
          "routes"
        ],
        "type": "object"
      },
      "EchoRequest": {
        "additionalProperties": false,
        "properties": {
          "message": {
            "description": "Message to echo back. Must not be empty.",
            "maxLength": 4096,
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "message"
        ],
        "type": "object"
      },
      "EchoResponse": {
        "additionalProperties": true,
        "properties": {
          "echo": {
            "type": "string"
          }
        },
        "required": [
          "echo"
        ],
        "type": "object"
      },
      "ErrorResponse": {
        "additionalProperties": false,
        "properties": {
          "error": {
            "type": "string"
          }
        },
        "required": [
          "error"
        ],
        "type": "object"
      },
      "GreetRequest": {
        "additionalProperties": false,
        "properties": {
          "name": {
            "description": "Name to greet. Omit to greet the world.",
            "maxLength": 4096,
            "type": "string"
          }
        },
        "type": "object"
      },
      "GreetResponse": {
        "additionalProperties": true,
        "properties": {
          "greeting": {
            "type": "string"
          },
          "server": {
            "type": "string"
          },
          "target": {
            "type": "string"
          }
        },
        "required": [
          "greeting",
          "target"
        ],
        "type": "object"
      },
      "HealthResponse": {
        "additionalProperties": false,
        "properties": {
          "status": {
            "const": "ok",
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "type": "object"
      },
      "HelpResponse": {
        "additionalProperties": true,
        "properties": {
          "actions": {
            "items": {
              "$ref": "#/components/schemas/ActionName"
            },
            "type": "array"
          },
          "examples": {
            "additionalProperties": true,
            "type": "object"
          },
          "mcp_only_actions": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "usage": {
            "type": "string"
          }
        },
        "required": [
          "actions",
          "mcp_only_actions",
          "usage",
          "examples"
        ],
        "type": "object"
      },
      "RestRoute": {
        "additionalProperties": false,
        "properties": {
          "action": {
            "type": [
              "string",
              "null"
            ]
          },
          "auth": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "method": {
            "type": "string"
          },
          "path": {
            "type": "string"
          }
        },
        "required": [
          "method",
          "path",
          "auth",
          "description"
        ],
        "type": "object"
      },
      "RestTruncationResponse": {
        "additionalProperties": false,
        "properties": {
          "error": {
            "const": "response exceeded REST response size limit",
            "type": "string"
          },
          "hint": {
            "type": "string"
          },
          "max_response_bytes": {
            "minimum": 1,
            "type": "integer"
          },
          "truncated": {
            "const": true,
            "type": "boolean"
          }
        },
        "required": [
          "truncated",
          "error",
          "max_response_bytes",
          "hint"
        ],
        "type": "object"
      },
      "StatusResponse": {
        "additionalProperties": true,
        "properties": {
          "note": {
            "type": "string"
          },
          "server": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "transport": {
            "type": "string"
          },
          "version": {
            "type": "string"
          }
        },
        "required": [
          "status"
        ],
        "type": "object"
      }
    },
    "securitySchemes": {
      "BearerAuth": {
        "bearerFormat": "opaque",
        "description": "Static bearer token in bearer mode; OAuth mode also uses bearer JWTs. Loopback and trusted-gateway modes may not require local auth.",
        "scheme": "bearer",
        "type": "http"
      }
    }
  },
  "info": {
    "description": "Generated OpenAPI schema for rmcp-template's direct REST surface. TEMPLATE: rename Example identifiers and action schemas when adapting. Auth modes: loopback/trusted-gateway deployments may have no local auth; mounted bearer mode uses RTEMPLATE_MCP_TOKEN; OAuth mode uses bearer JWTs. REST actions require their action-specific scopes when auth is mounted.",
    "title": "Example MCP REST API",
    "version": "0.4.3"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "operationId": "getHealth",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "examples": {
                  "ok": {
                    "value": {
                      "status": "ok"
                    }
                  }
                },
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Server is alive"
          }
        },
        "security": [],
        "summary": "Liveness probe",
        "tags": [
          "health"
        ]
      }
    },
    "/openapi.json": {
      "get": {
        "operationId": "getOpenApiSchema",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object"
                }
              }
            },
            "description": "Generated OpenAPI schema for the REST surface"
          }
        },
        "security": [],
        "summary": "OpenAPI schema",
        "tags": [
          "health"
        ]
      }
    },
    "/status": {
      "get": {
        "operationId": "getLocalStatus",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            },
            "description": "Runtime status with secrets redacted"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [],
        "summary": "Local runtime status",
        "tags": [
          "health"
        ]
      }
    },
    "/v1/capabilities": {
      "get": {
        "operationId": "getCapabilities",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CapabilitiesResponse"
                }
              }
            },
            "description": "Supported direct REST routes and metadata"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        },
        "security": [
          {
            "BearerAuth": []
          },
          {}
        ],
        "summary": "Direct REST route inventory",
        "tags": [
          "capabilities"
        ]
      }
    },
    "/v1/echo": {
      "post": {
        "description": "Direct REST route over the shared service layer.",
        "operationId": "postEcho",
        "requestBody": {
          "content": {
            "application/json": {
              "examples": {
                "echo": {
                  "value": {
                    "message": "Hello!"
                  }
                }
              },
              "schema": {
                "$ref": "#/components/schemas/EchoRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EchoResponse"
                }
              }
            },
            "description": "echo result"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "BearerAuth": []
          },
          {}
        ],
        "summary": "Run echo",
        "tags": [
          "direct-rest"
        ]
      }
    },
    "/v1/greet": {
      "post": {
        "description": "Direct REST route over the shared service layer.",
        "operationId": "postGreet",
        "requestBody": {
          "content": {
            "application/json": {
              "examples": {
                "greet": {
                  "value": {
                    "name": "Alice"
                  }
                }
              },
              "schema": {
                "$ref": "#/components/schemas/GreetRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GreetResponse"
                }
              }
            },
            "description": "greet result"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "BearerAuth": []
          },
          {}
        ],
        "summary": "Run greet",
        "tags": [
          "direct-rest"
        ]
      }
    },
    "/v1/help": {
      "get": {
        "description": "Direct REST route over the shared service layer.",
        "operationId": "getHelp",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HelpResponse"
                }
              }
            },
            "description": "help result"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "BearerAuth": []
          },
          {}
        ],
        "summary": "Run help",
        "tags": [
          "direct-rest"
        ]
      }
    },
    "/v1/status": {
      "get": {
        "description": "Direct REST route over the shared service layer.",
        "operationId": "getStatus",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusResponse"
                }
              }
            },
            "description": "status result"
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalError"
          }
        },
        "security": [
          {
            "BearerAuth": []
          },
          {}
        ],
        "summary": "Run status",
        "tags": [
