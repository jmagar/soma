{
  "$schema": "https://schema.tauri.app/config/2",
  "app": {
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    },
    "windows": [
      {
        "alwaysOnTop": true,
        "center": true,
        "decorations": false,
        "height": 520,
        "label": "main",
        "minHeight": 56,
        "minWidth": 560,
        "resizable": true,
        "shadow": true,
        "skipTaskbar": true,
        "title": "Labby Palette",
        "transparent": true,
        "visible": false,
        "width": 760
      }
    ]
  },
  "build": {
    "beforeBuildCommand": "pnpm vite:build",
    "beforeDevCommand": "pnpm vite:dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "category": "DeveloperTool",
    "icon": [
      "icons/icon.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "longDescription": "Labby Palette provides a native desktop command surface for Labby gateway actions.",
    "shortDescription": "Native command palette for Labby",
    "targets": [
      "deb",
      "rpm",
      "app",
      "dmg",
      "msi",
      "nsis"
    ]
  },
  "identifier": "tv.tootie.lab.palette",
  "productName": "Labby Palette",
  "version": "0.1.0"
}
