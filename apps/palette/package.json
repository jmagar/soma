  "name": "labby-palette-tauri",
  "packageManager": "pnpm@9.15.9",
  "private": true,
  "scripts": {
    "build": "tauri build",
    "coverage": "vitest run --coverage",
    "dev": "tauri dev",
    "format": "biome format --write . && biome check --write .",
    "lint": "biome lint .",
    "preview": "vite preview",
    "smoke:agent-os": "bash scripts/agent-os-smoke.sh",
    "smoke:desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-smoke.ps1",
    "smoke:live": "bash scripts/live-smoke.sh",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm install --frozen-lockfile && pnpm lint && pnpm test && pnpm typecheck && pnpm vite:build",
    "vite:build": "vite build",
    "vite:dev": "vite --host 127.0.0.1"
  },
  "type": "module",
  "version": "0.1.0"
