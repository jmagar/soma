# Copy this file outside the repo, fill in local values, then run:
# powershell -NoProfile -ExecutionPolicy Bypass -File scripts/desktop-smoke.ps1 -EnvFile C:\path\palette-smoke.env
#
# On a remote Windows desktop session, run this through an interactive scheduled
# task (`schtasks /IT`) so SendKeys and screenshots target the visible desktop.

LABBY_PALETTE_EXE=C:\path\to\labby-palette-tauri.exe
LABBY_PALETTE_API_URL=http://127.0.0.1:8765
LABBY_PALETTE_TOKEN=replace-with-local-dev-token
LABBY_PALETTE_QUERY=gateway
LABBY_PALETTE_EVIDENCE_DIR=C:\Temp\labby-palette-smoke

# Optional for `pnpm smoke:live`: execute a known-safe tool after catalog/schema smoke.
# LABBY_PALETTE_EXECUTE_ID=mcp:example::ping
# LABBY_PALETTE_EXECUTE_PARAMS={"message":"hello"}

# Optional for `pnpm smoke:agent-os`: copy the exe/script/env to a Windows host
# reachable by SSH. Keep these generic; do not commit machine-specific values.
# LABBY_PALETTE_WINDOWS_SSH=windows-test-host
# LABBY_PALETTE_WINDOWS_DIR=C:/Users/Public/labby-palette-smoke
