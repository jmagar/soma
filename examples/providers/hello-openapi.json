{
  "schema_version": 1,
  "provider": {
    "name": "hello-openapi",
    "kind": "openapi",
    "title": "Hello OpenAPI",
    "version": "0.1.0"
  },
  "tools": [
    {
      "name": "hello_openapi",
      "description": "OpenAPI provider example action.",
      "input_schema": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        },
        "additionalProperties": false
      },
      "output_schema": {
        "type": "object",
        "additionalProperties": true
      },
      "rest": {
        "enabled": true,
        "method": "POST",
        "path": "/hello"
      },
      "meta": {
        "openapi": {
          "method": "POST",
          "path": "/hello"
        }
      }
    }
  ],
  "capabilities": {
    "network": {
      "enabled": true,
      "allowed_hosts": ["127.0.0.1"]
    }
  },
  "meta": {
    "openapi": {
      "base_url": "http://127.0.0.1:9",
      "spec": "./examples/providers/openapi/hello.yaml"
    }
  }
}
