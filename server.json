{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "_meta": {
    "ai.dinglebear.soma": {
      "auth_modes": [
        "loopback-dev",
        "bearer",
        "oauth",
        "trusted-gateway"
      ],
      "binary": "soma",
      "config_home": "~/.soma",
      "container_data_dir": "/data",
      "default_http_endpoint": "http://127.0.0.1:40060/mcp",
      "default_provider_dir": "providers",
      "default_remote_endpoint": "https://soma.dinglebear.ai/mcp",
      "generated_docs": {
        "openapi": "docs/generated/openapi.json",
        "plugin": "docs/generated/plugin.json",
        "provider_surfaces": "docs/generated/provider-surfaces.md"
      },
      "homepage": "https://soma.dinglebear.ai",
      "keywords": [
        "mcp",
        "mcp-server",
        "model-context-protocol",
        "rmcp",
        "rust",
        "agent-tools",
        "ai-agents",
        "provider-runtime",
        "providers",
        "developer-tools",
        "automation",
        "openapi",
        "docker",
        "cli",
        "server-runtime"
      ],
      "node_package": "soma-rmcp",
      "provider_dir_env": "SOMA_PROVIDER_DIR",
      "repository": "https://github.com/dinglebear-ai/soma",
      "security_policy": "https://github.com/dinglebear-ai/soma/security/policy",
      "server_binary": "soma",
      "support_url": "https://github.com/dinglebear-ai/soma/issues",
      "surfaces": [
        "mcp",
        "cli",
        "rest",
        "web",
        "docker",
        "plugins"
      ],
      "transports": [
        "stdio",
        "streamable-http"
      ]
    },
    "io.modelcontextprotocol.registry/publisher-provided": {
      "distribution": {
        "ociImage": "ghcr.io/dinglebear-ai/soma:0.5.0"
      },
      "documentation": {
        "configuration": "docs/CONFIG.md",
        "environment": "docs/ENV.md",
        "quickstart": "docs/QUICKSTART.md",
        "readme": "README.md",
        "security": "https://github.com/dinglebear-ai/soma/security/policy",
        "support": "https://github.com/dinglebear-ai/soma/issues",
        "website": "https://soma.dinglebear.ai"
      },
      "publisher": {
        "name": "dinglebear.ai",
        "url": "https://dinglebear.ai"
      }
    }
  },
  "description": "Drop-in RMCP runtime for provider-backed MCP tools, prompts, resources, and agent capabilities.",
  "icons": [
    {
      "mimeType": "image/png",
      "sizes": [
        "512x512"
      ],
      "src": "https://raw.githubusercontent.com/dinglebear-ai/soma/main/plugins/soma/assets/icon.png"
    },
    {
      "mimeType": "image/svg+xml",
      "sizes": [
        "any"
      ],
      "src": "https://raw.githubusercontent.com/dinglebear-ai/soma/main/plugins/soma/assets/logo.svg",
      "theme": "dark"
    }
  ],
  "name": "ai.dinglebear/soma",
  "packages": [
    {
      "environmentVariables": [
        {
          "default": "/data",
          "description": "Runtime data directory inside the Soma container.",
          "format": "filepath",
          "isRequired": false,
          "isSecret": false,
          "name": "SOMA_HOME",
          "placeholder": "/data"
        },
        {
          "default": "/data/providers",
          "description": "Directory scanned for drop-in provider manifests and modules.",
          "format": "filepath",
          "isRequired": false,
          "isSecret": false,
          "name": "SOMA_PROVIDER_DIR",
          "placeholder": "/data/providers"
        },
        {
          "description": "Optional deployed platform API or upstream API base URL used by the SomaClient compatibility layer. Leave unset for local provider/runtime mode.",
          "isRequired": false,
          "isSecret": false,
          "name": "SOMA_API_URL",
          "placeholder": "https://api.example.com"
        },
        {
          "description": "Optional bearer token or upstream API key for provider-backed calls that use SomaClient. Keep secret.",
          "isRequired": false,
          "isSecret": true,
          "name": "SOMA_API_KEY"
        },
        {
          "default": "info",
          "description": "Rust tracing filter for local CLI and stdio MCP logs.",
          "isRequired": false,
          "isSecret": false,
          "name": "RUST_LOG"
        }
      ],
      "identifier": "ghcr.io/dinglebear-ai/soma:0.5.0",
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp"
        }
      ],
      "registryType": "oci",
      "runtimeHint": "docker",
      "transport": {
        "type": "stdio"
      }
    }
  ],
  "repository": {
    "id": "1238227299",
    "source": "github",
    "url": "https://github.com/dinglebear-ai/soma"
  },
  "title": "Soma",
  "version": "0.5.0",
  "websiteUrl": "https://soma.dinglebear.ai"
}
