<!-- CUSTOMIZE: server.json — MCP Registry manifest for publishing your server.
     See docs/MCP-REGISTRY-PUBLISH-GUIDE.md for step-by-step publishing instructions.

     Field reference:
       $schema        — Always use this exact URL for 2025-12-11 schema validation.
       name           — CUSTOMIZE: Reverse-DNS namespace: "yourdomain.com/your-service-mcp".
                        Use the domain you own (DNS-based identity proof required to publish).
                        The tv.tootie/ prefix belongs to this project's author.
       title          — CUSTOMIZE: Human-readable display name shown in MCP registry UIs.
       description    — CUSTOMIZE: One-sentence description of what the server does.
       repository.url — CUSTOMIZE: Your GitHub (or GitLab) repo URL.
       repository.source — Leave as "github" (or change to "gitlab").
       version        — CUSTOMIZE: Semantic version. Automated by release.yml on tags.
       packages       — List of distribution packages. OCI (Docker) is the standard format.
         registryType — "oci" for container images. Other options: "npm", "pypi".
         identifier   — CUSTOMIZE: Full OCI image ref with version tag.
                        Pattern: ghcr.io/<org>/<repo>:<version>
         version      — CUSTOMIZE: Must match the top-level version field.
         environmentVariables — All env vars the container needs. List every required var.
           name        — Exact env var name (used by registry UIs to generate setup forms).
           description — CUSTOMIZE: User-visible description shown in the registry UI.
           isRequired  — true: server fails to start without it. false: optional feature.
           isSecret    — true: registry UI masks the value (API keys, tokens, passwords).
       remotes        — CUSTOMIZE: Where users connect to a hosted instance of this server.
                        Remove this block if you don't run a public hosted instance.
         type         — "streamable-http" is the modern MCP transport (preferred over SSE).
         url          — CUSTOMIZE: Replace with your actual hosted /mcp endpoint URL.
-->
{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "description": "Soma is a batteries-included RMCP runtime for drop-in tools, prompts, resources, and provider-backed agent capabilities.",
  "name": "tv.tootie/soma",
  "packages": [
    {
      "environmentVariables": [
        {
          "description": "CUSTOMIZE: Replace with your service's base URL description. Example: 'Base URL of your Soma runtime, e.g. https://api.example.com/v1'.",
          "isRequired": true,
          "isSecret": false,
          "name": "SOMA_API_URL"
        },
        {
          "description": "CUSTOMIZE: Replace with your service's API key description. Example: 'API key for authenticating to the Soma runtime.'",
          "isRequired": true,
          "isSecret": true,
          "name": "SOMA_API_KEY"
        },
        {
          "description": "Bearer token for MCP endpoint authentication. All /mcp requests must include: Authorization: Bearer <token>. Generate with: openssl rand -hex 32.",
          "isRequired": false,
          "isSecret": true,
          "name": "SOMA_MCP_TOKEN"
        }
      ],
      "identifier": "ghcr.io/jmagar/soma:0.4.6",
      "registryType": "oci",
      "version": "0.4.6"
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://example.yourdomain.com/mcp"
    }
  ],
  "repository": {
    "source": "github",
    "url": "https://github.com/jmagar/soma"
  },
  "title": "Soma",
  "version": "0.4.6"
}
